{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.base.json"],
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "PORT",
    "APP_URL",
    "APP_VERSION",
    "LOG_LEVEL",
    "MONGODB_URI",
    "REDIS_URL",
    "REDIS_TLS",
    "AUTH_SECRET",
    "AUTH_URL",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",
    "AUTH_GITHUB_ID",
    "AUTH_GITHUB_SECRET",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_PRO_PRICE_ID",
    "STRIPE_TEAM_PRICE_ID",
    "ANTHROPIC_API_KEY",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_BUCKET_NAME",
    "R2_ENDPOINT",
    "R2_CDN_URL",
    "RESEND_API_KEY",
    "EMAIL_FROM",
    "SENTRY_DSN",
    "POSTHOG_API_KEY",
    "POSTHOG_HOST",
    "SLACK_WEBHOOK_URL",
    "BROWSER_POOL_SIZE",
    "BROWSER_RECYCLE_AFTER",
    "WORKER_CONCURRENCY",
    "HEALTH_PORT",
    "MEMORY_LIMIT_MB",
    "NEXT_PUBLIC_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:smoke": {
      "cache": false,
      "env": ["BASE_URL", "API_KEY"]
    },
    "clean": {
      "cache": false
    }
  }
}
