# =============================================================================
# AUDEX — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values.
# DO NOT commit `.env.local` — it's git-ignored.
#
# Required for `pnpm dev`: MONGODB_URI, REDIS_URL, AUTH_SECRET
# Everything else is optional in development.

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
APP_VERSION=0.0.0
LOG_LEVEL=debug

# ─── Database [REQUIRED] ─────────────────────────────────────────────────────
# Local dev (via docker-compose): mongodb://localhost:27017/audex
# Production: MongoDB Atlas (free M0, 512MB) — https://cloud.mongodb.com
MONGODB_URI=mongodb://localhost:27017/audex

# ─── Cache / Queue [REQUIRED] ────────────────────────────────────────────────
# Local dev (via docker-compose): redis://localhost:6379
# Production: Upstash free tier (10K cmds/day) — https://console.upstash.com
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ─── Auth [REQUIRED] ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
AUTH_SECRET=change-me-to-at-least-32-characters-minimum
AUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth — https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── Stripe (Billing) ────────────────────────────────────────────────────────
# Test mode: https://dashboard.stripe.com/test/apikeys
# Webhook secret: pnpm dlx stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# ─── AI (Anthropic Claude) ───────────────────────────────────────────────────
# Cost: ~$0.01 per report. Optional — AI summary skipped if not set.
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Object Storage (Cloudflare R2) ──────────────────────────────────────────
# Free tier: 10GB storage, $0 egress
# Setup: https://developers.cloudflare.com/r2/api/s3/tokens/
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=audex-screenshots
R2_ENDPOINT=
R2_CDN_URL=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Free tier: 100 emails/day — https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=Audex <noreply@audex.dev>

# ─── Monitoring ──────────────────────────────────────────────────────────────
# Sentry — free tier: 5K errors/mo
SENTRY_DSN=
# Build-time only — required for source map upload. Generate at
# https://sentry.io/settings/account/api/auth-tokens/ with the
# project:releases scope. Leaving these blank disables source map upload.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog — free tier: 1M events/mo, 5K sessions/mo
# Get key: https://us.posthog.com/project/settings
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ─── Slack (Team+ notifications) ─────────────────────────────────────────────
# Optional. Used for in-app team notifications and admin DLQ alerts.
SLACK_WEBHOOK_URL=

# ─── Workers ─────────────────────────────────────────────────────────────────
BROWSER_POOL_SIZE=3
BROWSER_RECYCLE_AFTER=50
WORKER_CONCURRENCY=3
HEALTH_PORT=8080
MEMORY_LIMIT_MB=1800

# ─── Client-Side (NEXT_PUBLIC_ — exposed to browser, NO SECRETS) ─────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Local Dev: Mongo Express UI ─────────────────────────────────────────────
# Basic auth for http://localhost:8081
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin
