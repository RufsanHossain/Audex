# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  AUDEX — Environment Variables                                          ║
# ║  Copy this file to .env.local and fill in the values.                   ║
# ║  Required variables are marked with [REQUIRED].                         ║
# ║  Optional variables have sensible defaults or are only needed in prod.  ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
APP_VERSION=0.0.0
LOG_LEVEL=debug

# ── Database [REQUIRED] ──────────────────────────────────────────────────────
# MongoDB Atlas connection string. Create a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/audex?retryWrites=true&w=majority

# ── Redis [REQUIRED] ─────────────────────────────────────────────────────────
# Upstash Redis URL. Create at https://console.upstash.com
REDIS_URL=rediss://default:xxxx@us1-xxxx.upstash.io:6379
REDIS_TLS=true

# ── Auth [REQUIRED] ──────────────────────────────────────────────────────────
# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-at-least-32-characters-long
AUTH_URL=http://localhost:3000

# Google OAuth (optional for local dev)
# Create at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (optional for local dev)
# Create at https://github.com/settings/applications/new
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Stripe (optional for local dev) ──────────────────────────────────────────
# Test mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRO_PRICE_ID=price_xxxx
STRIPE_TEAM_PRICE_ID=price_xxxx

# ── AI (optional for local dev) ──────────────────────────────────────────────
# Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxx

# ── Storage — Cloudflare R2 (optional for local dev) ─────────────────────────
# R2 credentials from https://dash.cloudflare.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=audex-screenshots
R2_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
R2_CDN_URL=https://cdn.audex.dev

# ── Email (optional for local dev) ───────────────────────────────────────────
# Resend API key from https://resend.com
RESEND_API_KEY=re_xxxx
EMAIL_FROM=Audex <noreply@audex.dev>

# ── Monitoring (optional for local dev) ──────────────────────────────────────
# Sentry DSN from https://sentry.io
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ── Workers ──────────────────────────────────────────────────────────────────
BROWSER_POOL_SIZE=3
BROWSER_RECYCLE_AFTER=50
WORKER_CONCURRENCY=3
HEALTH_PORT=8080
MEMORY_LIMIT_MB=1800

# ── Client-Side (NEXT_PUBLIC_ — exposed to browser) ─────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
