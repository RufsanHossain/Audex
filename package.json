{
  "name": "audex",
  "version": "0.0.0",
  "private": true,
  "description": "Audex — AI-powered code quality analysis platform",
  "author": "Rufsan",
  "license": "PROPRIETARY",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@audex/web",
    "dev:workers": "turbo dev --filter=@audex/workers",
    "build": "turbo build",
    "build:web": "turbo build --filter=@audex/web...",
    "build:workers": "turbo build --filter=@audex/workers...",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "typecheck": "turbo typecheck",
    "test": "turbo test:unit test:integration",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:smoke": "turbo test:smoke",
    "clean": "turbo clean && rm -rf node_modules",
    "db:migrate:up": "tsx packages/db/src/migrations/cli.ts up",
    "db:migrate:down": "tsx packages/db/src/migrations/cli.ts down",
    "db:migrate:status": "tsx packages/db/src/migrations/cli.ts status",
    "db:seed:staging": "tsx packages/db/src/seed/staging-seed.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@commitlint/types": "^20.4.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  }
}
